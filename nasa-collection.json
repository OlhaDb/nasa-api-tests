    {
      "name": "New Request",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Тест 1: статус код 200",
              "pm.test(\"Status is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// Тест 2: відповідь є JSON",
              "pm.test(\"Response is JSON\", function () {",
              "    pm.response.to.be.json;",
              "});",
              "",
              "// Тест 3: поле date існує",
              "pm.test(\"Has date field\", function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json.date).to.exist;",
              "});",
              "",
              "// Тест 4: date відповідає запитуваній",
              "pm.test(\"Date matches request\", function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json.date).to.eql(\"1995-12-04\");",
              "});",
              "",
              "// Тест 5: media_type є image або video",
              "pm.test(\"media_type is valid\", function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json.media_type).to.be.oneOf([\"image\", \"video\"]);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
